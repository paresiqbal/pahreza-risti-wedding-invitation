---
import { wedding } from "../data/wedding.config";
import GoldOrnament from "./GoldOrnament.astro";

const { gallery } = wedding;
---

<section class="bg-onyx px-6 py-24">
  <div class="mx-auto max-w-3xl text-center">
    <p data-reveal="fade" class="font-display text-xs tracking-[0.35em] text-gold-light uppercase">Galeri</p>
    <div data-reveal="fade" class="divider-gold mx-auto mt-4 w-40">
      <GoldOrnament variant="mark" class="h-3 w-12 shrink-0 text-gold" />
    </div>
  </div>

  <div data-reveal-group class="mx-auto mt-16 grid max-w-5xl grid-cols-2 gap-3 sm:grid-cols-3">
    {gallery.map((src, i) => (
      <div data-reveal="scale" class={`overflow-hidden border border-gold/20 ${i % 5 === 0 ? "sm:col-span-2 sm:row-span-2" : ""}`}>
        <img
          src={src}
          alt={`Galeri foto ${i + 1}`}
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
        />
      </div>
    ))}
  </div>
</section>
