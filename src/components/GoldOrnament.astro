---
// A hand-drawn-feeling corner ornament inspired by the "kawung" batik
// motif (overlapping ellipses). Used at hero corners and as a section
// mark. `variant="corner"` mirrors into all four corners via CSS;
// `variant="mark"` is a small standalone centerpiece for dividers.
interface Props {
  variant?: "corner" | "mark";
  class?: string;
}

const { variant = "corner", class: className = "" } = Astro.props;
---

{
  variant === "corner" ? (
    <svg
      viewBox="0 0 120 120"
      class={className}
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path
        d="M4 4 C 4 40, 4 70, 4 116"
        stroke="currentColor"
        stroke-width="1"
        opacity="0.8"
      />
      <path
        d="M4 4 C 40 4, 70 4, 116 4"
        stroke="currentColor"
        stroke-width="1"
        opacity="0.8"
      />
      <path
        d="M4 4 C 30 4, 4 30, 4 4"
        stroke="currentColor"
        stroke-width="1"
      />
      <g opacity="0.9">
        <ellipse cx="26" cy="26" rx="14" ry="9" transform="rotate(45 26 26)" stroke="currentColor" stroke-width="1" />
        <ellipse cx="26" cy="26" rx="14" ry="9" transform="rotate(-45 26 26)" stroke="currentColor" stroke-width="1" />
        <circle cx="26" cy="26" r="3" fill="currentColor" />
      </g>
      <circle cx="4" cy="4" r="2.5" fill="currentColor" />
    </svg>
  ) : (
    <svg
      viewBox="0 0 160 40"
      class={className}
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <ellipse cx="80" cy="20" rx="16" ry="10" transform="rotate(45 80 20)" stroke="currentColor" stroke-width="1" />
      <ellipse cx="80" cy="20" rx="16" ry="10" transform="rotate(-45 80 20)" stroke="currentColor" stroke-width="1" />
      <circle cx="80" cy="20" r="3.5" fill="currentColor" />
      <path d="M60 20 H10" stroke="currentColor" stroke-width="1" />
      <path d="M100 20 H150" stroke="currentColor" stroke-width="1" />
      <circle cx="10" cy="20" r="2" fill="currentColor" />
      <circle cx="150" cy="20" r="2" fill="currentColor" />
    </svg>
  )
}
