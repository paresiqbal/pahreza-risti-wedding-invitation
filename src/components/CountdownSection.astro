---
import { wedding } from "../data/wedding.config";

const targetDate = new Date(2026, 7, 2, 8, 0, 0);
const targetISO = `${targetDate.getFullYear()}-${String(targetDate.getMonth() + 1).padStart(2, "0")}-${String(targetDate.getDate()).padStart(2, "0")}T${String(targetDate.getHours()).padStart(2, "0")}:${String(targetDate.getMinutes()).padStart(2, "0")}`;
---

<section class="bg-onyx px-6 py-20 text-center text-ivory">
  <p
    data-reveal="fade"
    class="font-display text-xs tracking-[0.35em] text-gold-light uppercase"
  >
    Menuju Hari Bahagia
  </p>

  <div
    id="countdown"
    data-target={targetISO}
    data-reveal-group
    class="mx-auto mt-8 grid max-w-lg grid-cols-4 gap-3 sm:gap-6"
  >
    {
      ["days", "hours", "minutes", "seconds"].map((unit) => (
        <div
          data-reveal="scale"
          class="flex flex-col items-center border border-gold/30 px-2 py-4 sm:px-4"
        >
          <span
            data-unit={unit}
            class="font-display text-3xl text-gold sm:text-4xl"
          >
            00
          </span>
          <span class="mt-2 text-[10px] tracking-[0.2em] text-ivory/50 uppercase sm:text-xs">
            {unit === "days"
              ? "Hari"
              : unit === "hours"
                ? "Jam"
                : unit === "minutes"
                  ? "Menit"
                  : "Detik"}
          </span>
        </div>
      ))
    }
  </div>
</section>

<script>
  function initCountdown() {
    const el = document.getElementById("countdown");
    if (!el) return;

    const target = new Date(el.dataset.target ?? "").getTime();
    if (Number.isNaN(target)) return;

    const tick = () => {
      const now = Date.now();
      const diff = Math.max(0, target - now);

      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
      const minutes = Math.floor((diff / (1000 * 60)) % 60);
      const seconds = Math.floor((diff / 1000) % 60);

      const values: Record<string, number> = { days, hours, minutes, seconds };
      for (const [unit, value] of Object.entries(values)) {
        const targetEl = el.querySelector(`[data-unit="${unit}"]`);
        if (targetEl) targetEl.textContent = String(value).padStart(2, "0");
      }
    };

    tick();
    setInterval(tick, 1000);
  }

  initCountdown();
</script>
