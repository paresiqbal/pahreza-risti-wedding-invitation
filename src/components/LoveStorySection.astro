---
import { wedding } from "../data/wedding.config";
import GoldOrnament from "./GoldOrnament.astro";

const { loveStory } = wedding;
---

<section class="bg-ivory px-6 py-24">
  <div class="mx-auto max-w-2xl text-center">
    <p data-reveal="fade" class="font-display text-xs tracking-[0.35em] text-gold uppercase">Kisah Kami</p>
    <div data-reveal="fade" class="divider-gold mx-auto mt-4 w-40">
      <GoldOrnament variant="mark" class="h-3 w-12 shrink-0 text-gold" />
    </div>
  </div>

  <ol data-reveal-group class="mx-auto mt-16 max-w-xl border-l border-gold/30 pl-8">
    {loveStory.map((moment) => (
      <li data-reveal="left" class="relative mb-12 last:mb-0">
        <span class="absolute -left-[38px] top-1 h-3 w-3 rounded-full border border-gold bg-ivory"></span>
        <p class="text-xs tracking-[0.2em] text-gold-deep uppercase">{moment.date}</p>
        <h3 class="font-display mt-2 text-xl text-onyx">{moment.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-onyx-soft/70">{moment.description}</p>
      </li>
    ))}
  </ol>
</section>
