---
import { wedding } from "../data/wedding.config";
---

<button
  id="music-toggle"
  type="button"
  aria-label="Putar musik latar"
  aria-pressed="false"
  class="fixed bottom-6 right-6 z-40 flex h-12 w-12 items-center justify-center rounded-full border border-gold bg-onyx/90 text-gold shadow-lg backdrop-blur transition-transform duration-300 hover:scale-105"
>
  <!-- spinning vinyl-style ring, animates only while playing -->
  <span
    id="music-icon"
    class="relative flex h-6 w-6 items-center justify-center"
  >
    <svg
      viewBox="0 0 24 24"
      class="h-5 w-5"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        d="M9 18V5l12-2v13"
        stroke="currentColor"
        stroke-width="1.4"
        fill="none"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
      <circle
        cx="6"
        cy="18"
        r="3"
        stroke="currentColor"
        stroke-width="1.4"
        fill="none"></circle>
      <circle
        cx="18"
        cy="16"
        r="3"
        stroke="currentColor"
        stroke-width="1.4"
        fill="none"></circle>
    </svg>
  </span>
</button>

<audio id="wedding-audio" loop preload="auto">
  <source src={wedding.music.src} type="audio/mpeg" />
</audio>

<script>
  const btn = document.getElementById("music-toggle");
  const icon = document.getElementById("music-icon");
  const audio = document.getElementById(
    "wedding-audio",
  ) as HTMLAudioElement | null;

  function setPlayingState(isPlaying: boolean) {
    btn?.setAttribute("aria-pressed", String(isPlaying));
    icon?.classList.toggle("animate-spin-slow", isPlaying);
  }

  btn?.addEventListener("click", () => {
    if (!audio) return;
    if (audio.paused) {
      audio.load();
      audio.play().catch(() => {});
      setPlayingState(true);
    } else {
      audio.pause();
      setPlayingState(false);
    }
  });

  // If CoverGate already started playback on "Buka Undangan", reflect that.
  audio?.addEventListener("play", () => setPlayingState(true));
  audio?.addEventListener("pause", () => setPlayingState(false));
</script>

<style>
  @keyframes spin-slow {
    to {
      transform: rotate(360deg);
    }
  }
  :global(.animate-spin-slow) {
    animation: spin-slow 4s linear infinite;
  }
</style>
