---
import { wedding } from "../data/wedding.config";
import GoldOrnament from "./GoldOrnament.astro";

const { groom, bride, openingQuote } = wedding;

const weddingDate = new Date(wedding.events[0].date);
const formattedDate = weddingDate.toLocaleDateString("id-ID", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<section class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden bg-onyx px-6 py-24 text-center text-ivory">
  <GoldOrnament variant="corner" class="absolute top-6 left-6 h-14 w-14 text-gold/70" />
  <GoldOrnament variant="corner" class="absolute top-6 right-6 h-14 w-14 rotate-90 text-gold/70" />
  <GoldOrnament variant="corner" class="absolute bottom-6 left-6 h-14 w-14 -rotate-90 text-gold/70" />
  <GoldOrnament variant="corner" class="absolute bottom-6 right-6 h-14 w-14 rotate-180 text-gold/70" />

  <p data-reveal="fade" class="font-display text-xs tracking-[0.35em] text-gold-light uppercase">
    Undangan Pernikahan
  </p>

  <h1 data-reveal="scale" style="--reveal-delay: 120ms" class="font-script mt-6 text-7xl text-gold sm:text-8xl">
    {groom.nickname}
    <span class="mx-2 block font-body text-lg tracking-[0.4em] text-ivory/50 uppercase sm:inline">&amp;</span>
    {bride.nickname}
  </h1>

  <p data-reveal="fade" style="--reveal-delay: 260ms" class="font-display mt-6 text-lg text-ivory/80">{formattedDate}</p>

  <div data-reveal="fade" style="--reveal-delay: 340ms" class="divider-gold mt-10 w-64">
    <GoldOrnament variant="mark" class="h-4 w-16 shrink-0 text-gold" />
  </div>

  <blockquote data-reveal="fade" style="--reveal-delay: 420ms" class="mt-10 max-w-md">
    <p class="font-display text-sm leading-relaxed text-ivory/70 italic">
      &ldquo;{openingQuote.text}&rdquo;
    </p>
    <cite class="mt-3 block text-xs tracking-[0.2em] text-gold-light not-italic uppercase">
      {openingQuote.source}
    </cite>
  </blockquote>
</section>
