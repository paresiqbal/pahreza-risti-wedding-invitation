---
import { wedding } from "../data/wedding.config";
import GoldOrnament from "./GoldOrnament.astro";

const { groom, bride } = wedding;
---

<div
  id="cover-gate"
  class="fixed inset-0 z-50 flex flex-col items-center justify-between overflow-hidden bg-onyx px-6 py-12 text-ivory transition-opacity duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]"
>
  <!-- corner ornaments -->
  <GoldOrnament
    variant="corner"
    class="absolute top-4 left-4 h-16 w-16 text-gold"
  />
  <GoldOrnament
    variant="corner"
    class="absolute top-4 right-4 h-16 w-16 rotate-90 text-gold"
  />
  <GoldOrnament
    variant="corner"
    class="absolute bottom-4 left-4 h-16 w-16 -rotate-90 text-gold"
  />
  <GoldOrnament
    variant="corner"
    class="absolute bottom-4 right-4 h-16 w-16 rotate-180 text-gold"
  />

  <p
    class="font-display mt-10 text-xs tracking-[0.35em] text-gold-light uppercase"
  >
    The Wedding Of
  </p>

  <div class="flex flex-1 flex-col items-center justify-center text-center">
    <h1 class="font-script text-6xl leading-tight text-gold sm:text-7xl">
      {groom.nickname} &amp; {bride.nickname}
    </h1>

    <div class="divider-gold mt-8 w-48">
      <GoldOrnament variant="mark" class="h-4 w-16 shrink-0 text-gold" />
    </div>

    <div class="mt-8 space-y-1">
      <p class="font-body text-xs tracking-[0.2em] text-ivory/60 uppercase">
        Kepada Yth. Bapak/Ibu/Saudara/i
      </p>
      <p id="guest-name" class="font-display text-2xl text-ivory">
        Tamu Undangan
      </p>
    </div>
  </div>

  <button
    id="open-invitation"
    type="button"
    class="group mb-6 flex items-center gap-3 border border-gold px-8 py-3 font-body text-xs tracking-[0.3em] text-gold uppercase transition-colors duration-300 hover:bg-gold hover:text-onyx"
  >
    <span>Buka Undangan</span>
    <span class="transition-transform duration-300 group-hover:translate-x-1"
      >→</span
    >
  </button>
</div>

<script>
  // Guest name from ?to= query param — this is the templated part per-guest.
  const params = new URLSearchParams(window.location.search);
  const guest = params.get("to");
  const guestNameEl = document.getElementById("guest-name");
  if (guest && guestNameEl) {
    guestNameEl.textContent = decodeURIComponent(guest).replace(/\+/g, " ");
  }

  // Lock scroll until the invitation is opened.
  document.documentElement.style.overflow = "hidden";

  const gate = document.getElementById("cover-gate");
  const openBtn = document.getElementById("open-invitation");

  openBtn?.addEventListener("click", () => {
    document.documentElement.style.overflow = "";
    gate?.classList.add("opacity-0", "pointer-events-none");
    // Let the fade finish before removing from layout entirely.
    setTimeout(() => gate?.remove(), 700);

    // Optional: start background music on first user gesture.
    const audio = document.getElementById(
      "wedding-audio",
    ) as HTMLAudioElement | null;
    if (audio) {
      audio.load();
      audio.play().catch(() => {
        /* autoplay can still be blocked by the browser; ignore silently */
      });
    }
  });
</script>
