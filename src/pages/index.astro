---
import Layout from "../layouts/Layout.astro";
import CoverGate from "../components/CoverGate.astro";
import Hero from "../components/Hero.astro";
import CoupleSection from "../components/CoupleSection.astro";
import CountdownSection from "../components/CountdownSection.astro";
import EventSection from "../components/EventSection.astro";
import LoveStorySection from "../components/LoveStorySection.astro";
import GallerySection from "../components/GallerySection.astro";
import RSVPSection from "../components/RSVPSection.astro";
import GiftSection from "../components/GiftSection.astro";
import Footer from "../components/Footer.astro";
import MusicToggle from "../components/MusicToggle.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
---

<Layout>
  <CoverGate />
  <MusicToggle />
  <main>
    <Hero />
    <CoupleSection />
    <CountdownSection />
    <EventSection />
    <LoveStorySection />
    <GallerySection />
    <RSVPSection />
    <GiftSection />
